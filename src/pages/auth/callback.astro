---
// OAuth Callback Page - Client Side Handler
// Handles Supabase implicit OAuth flow (tokens in URL hash)

import { supabase } from '../../lib/supabase'

// Pre-render this route
export const prerender = false

// Get OAuth error from URL (query param)
const error = Astro.url.searchParams.get('error')

let errorMessage = ''
let authorized = false

// Check for error in URL
if (error) {
  errorMessage = 'Authentication error occurred. Please try again.'
} else {
  // Check if we have a hash with access_token
  const hasHash = Astro.url.hash.length > 1

  if (!hasHash) {
    errorMessage = 'No authentication data received. Please try again.'
  } else {
    // Wait for Supabase to process hash and establish session
    await new Promise(resolve => setTimeout(resolve, 2000))

    // Get current session
    const { data: { session }, error: sessionError } = await supabase.auth.getSession()

    if (sessionError) {
      errorMessage = `Session error: ${sessionError.message || JSON.stringify(sessionError)}`
    } else if (!session) {
      errorMessage = 'Could not establish session. Please try again.'
    } else {
      // Check if user is authorized board member
      const { data: boardMember, error: memberError } = await supabase
        .from('board_members')
        .select('*')
        .eq('user_id', session.user.id)
        .single()

      if (memberError) {
        errorMessage = `Database error: ${memberError.message || JSON.stringify(memberError)}`
      } else if (!boardMember) {
        // Auto-add anyone with @abotspot.com email as board member
        const email = session.user.email || ''

        if (email.endsWith('@abotspot.com')) {
          const name = session.user.user_metadata?.full_name || session.user.user_metadata?.name || email.split('@')[0]

          console.log('Adding board member:', { userId: session.user.id, email, name })

          const { error: insertError } = await supabase
            .from('board_members')
            .insert({
              user_id: session.user.id,
              name: name,
              role: 'member'  // Default to member, can be upgraded later
            })

          if (insertError) {
            errorMessage = `Could not add as board member: ${insertError.message || JSON.stringify(insertError)}`
          } else {
            authorized = true
            console.log('Board member added successfully')
          }
        } else {
          errorMessage = 'You are not authorized as a board member. @abotspot.com accounts only.'
          await supabase.auth.signOut()
        }
      } else {
        authorized = true
        console.log('Existing board member found:', boardMember)
      }
    }
  }
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OAuth Callback - aBotSpot</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body style="font-family: Inter, sans-serif; margin: 0; padding: 0; background: linear-gradient(135deg, #eff6ff 0%, #ecfeff 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center;">
    <div style="text-align: center; padding: 2rem;">
      <script is:inline>
        const authorized = {authorized ? 'true' : 'false'};
        const errorMessage = {errorMessage ? JSON.stringify(errorMessage) : 'null'};

        console.log('Auth callback state:', { authorized, errorMessage });

        if (authorized) {
          // Success - redirect to dashboard
          window.location.href = '/board/dashboard';
        } else if (errorMessage) {
          // Error - redirect to login with error
          window.location.href = `/board/login?error=callback_error&message=${encodeURIComponent(errorMessage)}`;
        } else {
          // Unknown state - redirect to login
          window.location.href = '/board/login';
        }
      </script>
      <div style="display: flex; flex-direction: column; align-items: center; gap: 1rem;">
        <div style="width: 48px; height: 48px; border: 4px solid #3b82f6; border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite;"></div>
        <p style="color: #1f2937; margin: 0;">Processing sign in...</p>
        {errorMessage && (
          <div style="background: #fee2e2; border: 1px solid #fecaca; border-radius: 8px; padding: 1rem; margin-top: 1rem; max-width: 400px;">
            <p style="color: #991b1b; margin: 0; font-size: 14px;">{errorMessage}</p>
          </div>
        )}
      </div>
    </div>
    <style>
      @keyframes spin {
        to { transform: rotate(360deg); }
      }
    </style>
  </body>
</html>
