---
// OAuth Callback Page - Client Side Handler
// Handles Supabase implicit OAuth flow (tokens in URL hash)

// Pre-render this route
export const prerender = false

// Note: All logic is client-side - see script below
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OAuth Callback - aBotSpot</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body style="font-family: Inter, sans-serif; margin: 0; padding: 0; background: linear-gradient(135deg, #eff6ff 0%, #ecfeff 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center;">
    <div style="text-align: center; padding: 2rem;">
      <div style="display: flex; flex-direction: column; align-items: center; gap: 1rem; max-width: 500px;">
        <div id="spinner" style="width: 48px; height: 48px; border: 4px solid #3b82f6; border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite;"></div>
        <p id="status-text" style="color: #1f2937; margin: 0; font-size: 14px;">Initializing...</p>
        <div id="error-display" style="background: #fee2e2; border: 1px solid #fecaca; border-radius: 8px; padding: 1rem; margin-top: 1rem; max-width: 400px; text-align: left; display: none;">
          <p id="error-message" style="color: #991b1b; margin: 0; font-size: 14px; word-wrap: break-word;"></p>
        </div>
      </div>
    </div>

    <!-- Supabase JS Client -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

    <script>
      (async function() {
        const SUPABASE_URL = 'https://myqyqdiaoojoglxjwtnu.supabase.co';
        const SUPABASE_ANON_KEY = 'sb_publishable_Y4iHbWeFUm0Jj2xQls48fg_7dKmt99Q';

        // DOM elements
        const spinner = document.getElementById('spinner');
        const statusText = document.getElementById('status-text');
        const errorDisplay = document.getElementById('error-display');
        const errorMessage = document.getElementById('error-message');

        // Helper functions
        const showSpinner = () => {
          if (spinner) spinner.style.display = 'block';
          if (statusText) statusText.textContent = 'Processing sign in...';
        };

        const hideSpinner = () => {
          if (spinner) spinner.style.display = 'none';
        };

        const showError = (msg) => {
          console.error('Error:', msg);
          hideSpinner();
          if (statusText) statusText.textContent = 'Error occurred';
          if (errorDisplay) {
            errorDisplay.style.display = 'block';
            if (errorMessage) errorMessage.textContent = msg;
          }
        };

        const redirectToLogin = (msg) => {
          console.log('Redirecting to login with error:', msg);
          setTimeout(() => {
            window.location.href = '/board/login?error=callback_error&message=' + encodeURIComponent(msg);
          }, 2000);
        };

        const redirectToDashboard = () => {
          console.log('Redirecting to dashboard');
          setTimeout(() => {
            window.location.href = '/board/dashboard';
          }, 500);
        };

        try {
          // Initialize Supabase client
          console.log('Initializing Supabase client...');
          const supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

          // Check for error in URL
          const urlParams = new URLSearchParams(window.location.search);
          const oauthError = urlParams.get('error');

          console.log('URL params:', 'error=' + oauthError);

          if (oauthError) {
            showError('Authentication error occurred. Please try again.');
            redirectToLogin('OAuth error');
            return;
          }

          // Check if we have a hash with access_token
          const hasHash = window.location.hash.length > 1;

          if (!hasHash) {
            showError('No authentication data received. Please try again.');
            redirectToLogin('No hash');
            return;
          }

          console.log('Hash detected, waiting for Supabase to process...');

          // Wait for Supabase to process hash and establish session
          showSpinner();
          statusText.textContent = 'Establishing session...';
          await new Promise(resolve => setTimeout(resolve, 3000));

          console.log('Checking session...');

          // Get current session
          const { data: { session }, error: sessionError } = await supabaseClient.auth.getSession();

          if (sessionError) {
            showError('Session error: ' + JSON.stringify(sessionError));
            redirectToLogin(JSON.stringify(sessionError));
            return;
          }

          if (!session) {
            showError('Could not establish session. Session is null.');
            redirectToLogin('No session');
            return;
          }

          console.log('Session established:', session);

          // Check if user is authorized board member
          statusText.textContent = 'Checking authorization...';
          const { data: boardMember, error: memberError } = await supabaseClient
            .from('board_members')
            .select('*')
            .eq('user_id', session.user.id)
            .single();

          if (memberError) {
            showError('Database error: ' + JSON.stringify(memberError));
            redirectToLogin(JSON.stringify(memberError));
            return;
          }

          if (!boardMember) {
            // Auto-add anyone with @abotspot.com email as board member
            const email = session.user.email || '';

            console.log('Board member check:', 'found=' + false, 'email=' + email);

            if (email.endsWith('@abotspot.com')) {
              const name = session.user.user_metadata?.full_name || session.user.user_metadata?.name || email.split('@')[0];

              console.log('Adding board member:', 'userId=' + session.user.id, 'email=' + email, 'name=' + name);

              statusText.textContent = 'Adding to board members...';

              const { error: insertError } = await supabaseClient
                .from('board_members')
                .insert({
                  user_id: session.user.id,
                  name: name,
                  role: 'member'
                });

              if (insertError) {
                showError('Could not add as board member: ' + JSON.stringify(insertError));
                setTimeout(() => {
                  window.location.href = '/board/login?error=callback_error&message=' + encodeURIComponent(JSON.stringify(insertError));
                }, 3000);
              } else {
                console.log('Board member added successfully');
                redirectToDashboard();
              }
            } else {
              showError('You are not authorized as a board member. @abotspot.com accounts only.');
              setTimeout(() => {
                window.location.href = '/board/login?error=unauthorized';
              }, 3000);
            }
          } else {
            console.log('Existing board member found:', boardMember);
            redirectToDashboard();
          }
        } catch (error) {
          console.error('Unexpected error:', error);
          hideSpinner();
          if (statusText) statusText.textContent = 'Unexpected error';
          showError('An unexpected error occurred: ' + error.message);
          setTimeout(() => {
            window.location.href = '/board/login?error=callback_error';
          }, 3000);
        }
      })();
    </script>

    <style>
      @keyframes spin {
        to { transform: rotate(360deg); }
      }
    </style>
  </body>
</html>
