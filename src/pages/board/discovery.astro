---
// Grant Discovery Page
// Search and filter grants from Supabase database

import Layout from '../../layouts/Layout.astro'

const pageTitle = 'Grant Discovery - aBotSpot'
const pageDescription = 'Search and discover grants for aBotSpot projects'
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="min-h-screen bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 py-8">
      <!-- Page Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Grant Discovery</h1>
        <p class="text-gray-600 mt-2">Search and filter grants for aBotSpot projects</p>
      </div>

      <!-- Search & Filter Bar -->
      <div class="bg-white rounded-xl shadow-lg p-6 mb-8">
        <div class="flex flex-col lg:flex-row gap-4">
          <!-- Search Input -->
          <div class="flex-1">
            <label class="block text-sm font-medium text-gray-700 mb-2">Search</label>
            <input
              type="text"
              placeholder="Search by name, keywords, or description..."
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              id="searchInput"
            />
          </div>

          <!-- Status Filter -->
          <div class="lg:w-48">
            <label class="block text-sm font-medium text-gray-700 mb-2">Status</label>
            <select
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
              id="statusFilter"
            >
              <option value="">All Status</option>
              <option value="New">New</option>
              <option value="In Review">In Review</option>
              <option value="Approved">Approved</option>
              <option value="Rejected">Rejected</option>
              <option value="Awarded">Awarded</option>
              <option value="Completed">Completed</option>
            </select>
          </div>

          <!-- Focus Area Filter -->
          <div class="lg:w-48">
            <label class="block text-sm font-medium text-gray-700 mb-2">Focus Area</label>
            <select
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
              id="focusFilter"
            >
              <option value="">All Areas</option>
              <option value="AI Education">AI Education</option>
              <option value="Community Development">Community Development</option>
              <option value="Local Resilience">Local Resilience</option>
              <option value="Technology">Technology</option>
              <option value="Environment">Environment</option>
            </select>
          </div>
        </div>

        <!-- Add Grant Button -->
        <div class="mt-4 flex justify-end">
          <button
            id="addGrantBtn"
            class="px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors text-sm font-medium"
          >
            + Add Grant
          </button>
        </div>
      </div>

      <!-- Grant List -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        <!-- Sample Grant Cards (will be replaced with Supabase data) -->
        <div class="bg-white rounded-xl shadow-sm p-4 border-l-4 border-green-500 cursor-pointer hover:opacity-80 transition-opacity">
          <div class="flex items-start justify-between mb-2">
            <h3 class="text-sm font-semibold text-gray-900">OpenAI Partnership</h3>
            <span class="px-2 py-1 bg-blue-100 text-blue-600 rounded-full text-xs font-medium">New</span>
          </div>
          <p class="text-sm text-gray-700 mb-3">$50,000 for AI education platform development</p>
          <div class="flex items-center justify-between text-xs text-gray-500">
            <span>AI Education</span>
            <span>Submitted Jan 15, 2026</span>
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm p-4 border-l-4 border-yellow-500 cursor-pointer hover:opacity-80 transition-opacity">
          <div class="flex items-start justify-between mb-2">
            <h3 class="text-sm font-semibold text-gray-900">Google.org Grant</h3>
            <span class="px-2 py-1 bg-yellow-100 text-yellow-600 rounded-full text-xs font-medium">In Review</span>
          </div>
          <p class="text-sm text-gray-700 mb-3">Community development initiative - $25,000</p>
          <div class="flex items-center justify-between text-xs text-gray-500">
            <span>Community Development</span>
            <span>Submitted Feb 1, 2026</span>
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm p-4 border-l-4 border-purple-500 cursor-pointer hover:opacity-80 transition-opacity">
          <div class="flex items-start justify-between mb-2">
            <h3 class="text-sm font-semibold text-gray-900">Microsoft Education</h3>
            <span class="px-2 py-1 bg-purple-100 text-purple-600 rounded-full text-xs font-medium">Approved</span>
          </div>
          <p class="text-sm text-gray-700 mb-3">$100,000 for local resilience programs</p>
          <div class="flex items-center justify-between text-xs text-gray-500">
            <span>Local Resilience</span>
            <span>Dec 20, 2025</span>
          </div>
        </div>
      </div>

      <!-- Empty State -->
      <div id="loadingState" class="bg-white rounded-xl shadow-lg p-12 text-center hidden">
        <div class="flex flex-col items-center gap-3">
          <div class="w-12 h-12 border-4 border-t-4 border-gray-300 rounded-full animate-spin"></div>
          <p class="text-gray-600">Loading grants...</p>
        </div>
      </div>

      <div id="emptyState" class="bg-white rounded-xl shadow-lg p-12 text-center hidden">
        <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 0-6-6 12 6 12 6 6 0m-6 0-6-6 12 6 12 6 6 0m-6 0-6-6 12 6 12 6 6 0" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m-4 4h4m-2 2v4" />
        </svg>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">No Grants Found</h3>
        <p class="text-gray-600 mb-4">There are no grants matching your current filters. Try adjusting your search or filters.</p>
        <button
          class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium"
          onclick="window.location.reload()"
        >
          Clear Filters
        </button>
      </div>
    </div>

    <!-- Supabase Client -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

    <script client:only>
      (async function() {
        const SUPABASE_URL = 'https://myqyqdiaoojoglxjwtnu.supabase.co';
        const SUPABASE_ANON_KEY = 'sb_publishable_Y4iHbWeFUm0Jj2xQls48fg_7dKmt99Q';

        // Initialize Supabase client
        const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

        // Check session
        const { data: { session } } = await supabase.auth.getSession();

        if (!session) {
          console.error('No session found, redirecting to login');
          window.location.href = '/board/login';
          return;
        }

        console.log('Session found:', session.user.email);

        // Grant types
        const grantTypes = {
          'Community Development': 'community-dev',
          'AI Education': 'ai-edu',
          'Local Resilience': 'local-resilience',
          'Technology': 'tech',
          'Environment': 'environment'
        };

        // Fetch grants from Supabase
        async function fetchGrants() {
          document.getElementById('loadingState').classList.remove('hidden');
          document.getElementById('emptyState').classList.add('hidden');
          document.getElementById('grantsGrid').classList.remove('hidden');

          const { data: grants, error } = await supabase
            .from('grants')
            .select('*')
            .order('created_at', { ascending: false });

          if (error) {
            console.error('Error fetching grants:', error);
            alert('Error loading grants. Please try again.');
            document.getElementById('loadingState').classList.add('hidden');
            document.getElementById('emptyState').classList.remove('hidden');
            return;
          }

          if (!grants || grants.length === 0) {
            document.getElementById('loadingState').classList.add('hidden');
            document.getElementById('emptyState').classList.remove('hidden');
            return;
          }

          displayGrants(grants);
        }

        // Display grants
        function displayGrants(grants) {
          const grid = document.getElementById('grantsGrid');
          grid.innerHTML = '';

          grants.forEach(grant => {
            const statusColors = {
              'New': 'blue',
              'In Review': 'yellow',
              'Approved': 'purple',
              'Rejected': 'red',
              'Awarded': 'green',
              'Completed': 'gray'
            };

            const color = statusColors[grant.status] || 'gray';

            const card = document.createElement('div');
            card.className = 'bg-white rounded-xl shadow-sm p-4 border-l-4 border-' + color + '-500 cursor-pointer hover:opacity-80 transition-opacity';
            card.innerHTML = `
              <div class="flex items-start justify-between mb-2">
                <h3 class="text-sm font-semibold text-gray-900">${grant.name}</h3>
                <span class="px-2 py-1 bg-${color}-100 text-${color}-600 rounded-full text-xs font-medium">${grant.status}</span>
              </div>
              <p class="text-sm text-gray-700 mb-3">${grant.description || 'No description'}</p>
              <div class="flex items-center justify-between text-xs text-gray-500">
                <span>${grant.focus_area || 'General'}</span>
                <span>${new Date(grant.created_at).toLocaleDateString()}</span>
              </div>
            `;

            card.addEventListener('click', () => {
              // TODO: Open grant details modal
              console.log('Grant clicked:', grant.id);
            });

            grid.appendChild(card);
          });

          // Update counts
          document.getElementById('discoveryCount').textContent = grants.length;
        }

        // Filter grants
        function filterGrants() {
          const search = document.getElementById('searchInput').value.toLowerCase();
          const status = document.getElementById('statusFilter').value;
          const focus = document.getElementById('focusFilter').value;

          const { data: grants, error } = await supabase
            .from('grants')
            .select('*')
            .order('created_at', { ascending: false });

          if (error) {
            console.error('Error fetching grants:', error);
            alert('Error filtering grants. Please try again.');
            return;
          }

          let filtered = grants || [];

          if (status) {
            filtered = filtered.filter(g => g.status === status);
          }

          if (focus) {
            filtered = filtered.filter(g => g.focus_area === focus);
          }

          if (search) {
            filtered = filtered.filter(g => 
              g.name.toLowerCase().includes(search) ||
              (g.description && g.description.toLowerCase().includes(search)) ||
              (g.focus_area && g.focus_area.toLowerCase().includes(search))
            );
          }

          if (filtered.length === 0) {
            document.getElementById('loadingState').classList.add('hidden');
            document.getElementById('emptyState').classList.remove('hidden');
            document.getElementById('grantsGrid').classList.add('hidden');
            document.getElementById('discoveryCount').textContent = '0';
          } else {
            displayGrants(filtered);
          }
        }

        // Add event listeners
        document.getElementById('searchInput').addEventListener('input', debounce(filterGrants, 300));
        document.getElementById('statusFilter').addEventListener('change', filterGrants);
        document.getElementById('focusFilter').addEventListener('change', filterGrants);

        // Debounce helper
        function debounce(func, wait) {
          let timeout;
          return function executedFunction(...args) {
            const later = () => {
              clearTimeout(timeout);
              func(...args);
            };
            clearTimeout(timeout);
            timeout = setTimeout(later, wait);
          };
        }

        // Initial load
        await fetchGrants();
      })();
    </script>

    <style>
      @keyframes spin {
        to { transform: rotate(360deg); }
      }
    </style>
  </main>
</Layout>
